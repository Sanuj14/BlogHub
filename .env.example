# Copy this file to ".env" and fill in your own values.

# MongoDB Atlas connection string (see README for how to get one)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/bloghub?retryWrites=true&w=majority

# Secret used to sign login tokens – use a long random string
JWT_SECRET=replace_this_with_a_long_random_secret

# Optional – local port
PORT=3000

# SMTP settings for password-reset emails (e.g. Gmail, SendGrid, Mailgun)
# Leave blank to skip email sending in local dev (code is logged to console instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=BlogHub <you@gmail.com>
